# Default configuration for editors
# Respected by most editors like neovim and PyCharm
# Plugins available for VSCode and others.
# https://editorconfig.org/#pre-installed

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yaml,yml,lua, html}]
indent_size = 2

[*.{md}]
trim_trailing_whitespace = false
