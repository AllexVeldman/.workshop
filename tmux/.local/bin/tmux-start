#!/bin/bash


if [ "$TMUX_SESSION" = "" ]; then
    tmux
    exit 0
fi


tmux has-session -t $TMUX_SESSION &> /dev/null

if [ $? != 0 ]; then
    echo "Setting up tmux session '$TMUX_SESSION'"
    tmux new-session -s $TMUX_SESSION -d
    tmux send-keys -t $TMUX_SESSION:1 "${TMUX_EDITOR:="nvim"}" Enter
    tmux new-window -t $TMUX_SESSION: -d
fi

tmux attach -t $TMUX_SESSION
# vim: set filetype=sh
